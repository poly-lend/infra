# Polygon mainnet RPC endpoints (for mainnet listener and as the fork-url for anvil)
RPC_URL=https://polygon-rpc.com
WS_URL=wss://polygon-bor-rpc.publicnode.com

# Testnet PolyLend address + start block are resolved at runtime by the
# testnet-deploy compose service, which writes them to the testnet_deployments
# named volume; listener-testnet and api-testnet read from that volume and
# export POLYLEND_ADDRESS / START_BLOCK before starting node. No .env entries
# needed for backend. Webapp addresses are still hardcoded in webapp/src/chainConfig.ts
# for now.

# PostHog analytics (webapp + landing build args)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=

# Featurebase feedback widget (webapp + web-testnet-build build arg)
# Grab from Featurebase Settings → Developer → Org ID once poly-lend/proposals#27
# is complete. Leave empty to disable the widget; webapp no-ops gracefully.
VITE_PUBLIC_FEATUREBASE_ORG_ID=

# Polymarket CLOB API (server-side; backend consumer lands later)
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
